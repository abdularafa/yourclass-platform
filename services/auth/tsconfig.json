{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@yourclass/database": ["../packages/database/src"],
      "@yourclass/shared-types": ["../packages/shared-types/src"],
      "@yourclass/validators": ["../packages/validators/src"],
      "@yourclass/ui-tokens": ["../packages/ui-tokens/src"],
      "@yourclass/api-config": ["../packages/api-config/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
